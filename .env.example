# Server-side only. Never expose vendor secrets to browser code.
APP_BASE_URL=http://localhost:3000

# Required for durable production persistence.
DATABASE_URL=postgres://user:password@host:5432/outbound
# Set to false only for local/self-hosted Postgres without SSL.
DATABASE_SSL=true
DATABASE_POOL_MAX=5

# Required for internal push endpoint protection.
INTERNAL_API_SECRET=replac...cret

# Vendor/server credentials.
ANTHROPIC_API_KEY=replace-with-anthropic-key
EXA_API_KEY=replace-with-exa-key
BROWSERBASE_API_KEY=replace-with-browserbase-key
BROWSERBASE_PROJECT_ID=replace-with-browserbase-project-id
INSTANTLY_API_KEY=replace-with-instantly-key

# Required for public MCP route protection. Set MCP_AUTH_DISABLED=true only for a short local/pilot connector test.
MCP_API_SECRET=replace-with-long-random-secret
MCP_AUTH_DISABLED=false

# Cowork integration placeholders.
COWORK_API_BASE_URL=https://api.example-cowork.local
COWORK_API_KEY=replace-with-cowork-key
COWORK_WEBHOOK_SECRET=replace-with-cowork-webhook-secret
REVIEW_SIGNING_SECRET=replace-with-review-signing-secret
